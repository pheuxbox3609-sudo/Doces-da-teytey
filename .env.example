# Configurações do Email (para envio do formulário de contato)
# Nota: Para Gmail, você precisa gerar uma "Senha de App" nas configurações do Google

# Email que receberá as mensagens do formulário
EMAIL_DESTINO=seuemail@exemplo.com

# Email que enviará as mensagens (sua conta de email)
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS=suasenhadeseuappouapppassword

# Porta do servidor (padrão: 3000)
PORT=3000
